# StuntCock — Environment Variables
# Copy this file to .env and fill in your values

# Your Anthropic API key (required for LLM fallback)
# IMPORTANT: This must be set here in .env — it cannot be configured via the Settings UI.
ANTHROPIC_API_KEY=sk-ant-...

# Full path to the signal-cli binary on your system
# e.g. /usr/local/bin/signal-cli or /opt/homebrew/bin/signal-cli
SIGNAL_CLI_PATH=/usr/local/bin/signal-cli

# Port for the StuntCock Express backend
PORT=3001

# signal-cli JSON-RPC daemon port (default 8080, change if occupied)
SIGNAL_CLI_PORT=8080

# Your registered Signal phone number (E.164 format, e.g. +15550001234)
# Set after completing the setup wizard
SIGNAL_PHONE_NUMBER=

# URL of your running StuntCock backend (required when deploying frontend to Firebase Hosting)
# e.g. http://192.168.1.42:3001 or https://your-tunnel.ngrok.io
VITE_API_URL=http://localhost:3001

# WebSocket URL of your running StuntCock backend
VITE_WS_URL=ws://localhost:3001

# Path to the Chromium/Chrome binary used by whatsapp-web.js (Puppeteer).
# Required when running in a server environment without a bundled Chromium.
# e.g. /usr/bin/chromium-browser  or  /usr/bin/google-chrome
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
