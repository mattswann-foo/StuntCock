# StuntCock — Environment Variables
# Copy this file to .env and fill in your values

# Your Anthropic API key (required for LLM fallback)
# IMPORTANT: This must be set here in .env — it cannot be configured via the Settings UI.
ANTHROPIC_API_KEY=sk-ant-...

# Full path to the signal-cli binary on your system
# e.g. /usr/local/bin/signal-cli or /opt/homebrew/bin/signal-cli
SIGNAL_CLI_PATH=/usr/local/bin/signal-cli

# Port for the StuntCock Express backend
PORT=3001

# signal-cli JSON-RPC daemon port (default 8080, change if occupied)
SIGNAL_CLI_PORT=8080

# Your registered Signal phone number (E.164 format, e.g. +15550001234)
# Set after completing the setup wizard
SIGNAL_PHONE_NUMBER=

# URL of your running StuntCock backend (required when deploying frontend to Firebase Hosting)
# e.g. http://192.168.1.42:3001 or https://your-tunnel.ngrok.io
VITE_API_URL=http://localhost:3001

# WebSocket URL of your running StuntCock backend
VITE_WS_URL=ws://localhost:3001

# ── In-App Purchases ──────────────────────────────────────────────────────────

# Comma-separated list of product IDs available for purchase (read by the mobile app)
# e.g. com.mattswann.stuntcock.pro_monthly,com.mattswann.stuntcock.pro_yearly
EXPO_PUBLIC_IAP_PRODUCT_IDS=com.mattswann.stuntcock.pro_monthly

# Apple App Store Server API key (JWT bearer — from App Store Connect)
# Required only if you want backend-side receipt signature verification
# Leave blank to use JWS payload trust mode (suitable for development)
APPLE_APPSTORE_API_KEY=

# Google Play Android Developer API
# Either provide a raw access token OR a service account JSON blob
GOOGLE_PLAY_ACCESS_TOKEN=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.mattswann.stuntcock
